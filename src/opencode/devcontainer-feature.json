{
	"name": "opencode CLI",
	"id": "opencode",
	"version": "0.3.6",
	"description": "Installs the opencode AI coding agent CLI and ensures volume-mounted data directories are owned by the correct user.",
	"documentationURL": "https://opencode.ai",
	"options": {
		"username": {
			"type": "string",
			"default": "",
			"description": "Username to install opencode for. Defaults to _REMOTE_USER (the container's remote user)."
		},
		"version": {
			"type": "string",
			"default": "",
			"description": "Version to install (e.g. 1.3.17). Empty = latest."
		},
		"autoupdate": {
			"type": "boolean",
			"default": true,
			"description": "Enable auto-upgrade on container start"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"sst-dev.opencode"
			]
		}
	},
	"postStartCommand": "bash /usr/local/share/devcontainer-features/opencode-postStartCommand.sh",
	"installsAfter": ["ghcr.io/devcontainers/features/common-utils"]
}
